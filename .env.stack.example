# ═══════════════════════════════════════════════════════════════════════════════
# ReArch Docker Swarm Stack - Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values before deploying.
#
# Usage:
#   cp .env.stack.example .env
#   # Edit .env with your values
#   docker stack deploy -c docker-compose-traefik.yml rearch
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Domain ──────────────────────────────────────────────────────────────────
# Base domain for all services. Subdomains will be:
#   app.<DOMAIN>  → frontend
#   api.<DOMAIN>  → backend
#   auth.<DOMAIN> → keycloak
DOMAIN=yourdomain.example.com

# ─── JWT (used by backend for issuing app tokens) ────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRY=24h

# ─── Admin Bootstrap (created on first startup if no users exist) ────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password

# ─── Keycloak Admin ──────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin-password

# ─── Keycloak Database ───────────────────────────────────────────────────────
KEYCLOAK_DB_PASSWORD=change-me-keycloak-db-password

# ─── Keycloak Backend Client Secret ──────────────────────────────────────────
# After deploying, go to Keycloak admin > rearch realm > Clients > rearch-backend
# and copy the client secret here. Or update the realm-export.json before deploying.
KEYCLOAK_BACKEND_CLIENT_SECRET=CHANGE_ME_BACKEND_SECRET

# ─── OAuth2 Proxy ────────────────────────────────────────────────────────────
# Client secret for the rearch-proxy Keycloak client
OAUTH2_PROXY_CLIENT_SECRET=CHANGE_ME_PROXY_SECRET
# Generate with: openssl rand -base64 32 | tr -- '+/' '-_'
OAUTH2_PROXY_COOKIE_SECRET=change-me-cookie-secret-32bytes

# ─── Docker Container Image ──────────────────────────────────────────────────
CONVERSATION_CONTAINER_IMAGE=vscode-opencode:latest

# ─── Atlassian (optional) ────────────────────────────────────────────────────

# ─── MCP Proxy ───────────────────────────────────────────────────────────
# Shared secret for authenticating containers to the MCP proxy
# Generate with: openssl rand -base64 32
MCP_PROXY_SECRET=change-me-mcp-proxy-secret

# ─── Internal API (service-to-service) ───────────────────────────────────
# Shared secret between backend and MCP proxy for internal API calls
# (used by the MCP proxy to create conversations on behalf of users).
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=change-me-internal-api-secret
