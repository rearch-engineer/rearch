    "README.md"
  ],
  "keywords": [
    "rearch",
    "ai",
    "agents",
    "opencode",
    "cli",
    "docker",
    "automation"
  ],
  "author": "ReArch",
  "license": "Apache-2.0",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.5.1",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
