{
  "name": "rearch-cli",
  "version": "0.1.0",
  "description": "ReArch CLI - Run ReArch with a single command (no auth)",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "rearch": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun run src/index.ts",
    "prepublishOnly": "bun run build"
  },
  "files": [
