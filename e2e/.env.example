# ─── ReArch E2E Test Environment Variables ───
# Copy this file to .env and fill in the values before running tests.

# Base URL of the frontend application
PLAYWRIGHT_BASE_URL=http://localhost:4200

# Login credentials (LOCAL auth mode)
PLAYWRIGHT_USER_EMAIL=admin@example.com
PLAYWRIGHT_USER_PASSWORD=your-password

# BitBucket resource details
PLAYWRIGHT_BB_NAME=My Bitbucket
PLAYWRIGHT_BB_WORKSPACE=your-workspace-slug
PLAYWRIGHT_BB_EMAIL=your-email@example.com
PLAYWRIGHT_BB_USERNAME=your-bitbucket-username
PLAYWRIGHT_BB_API_TOKEN=your-api-token

# Repository to import and use
PLAYWRIGHT_BB_REPO_NAME=your-repo-name
