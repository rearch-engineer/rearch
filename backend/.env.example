MONGODB_URI=mongodb://localhost:27017/rearch
PORT=5000
DATA_PATH=./data

# ─── Authentication ────────────────────────────────────────────────────────────
# Auth mode: LOCAL (email/password), OAUTH (OpenID Connect), or KEYCLOAK_FIREWALL
AUTH_MODE=LOCAL

# JWT secret key for signing tokens (REQUIRED - use a strong random string)
JWT_SECRET=change-me-to-a-strong-random-secret
# JWT token expiry (default: 24h)
JWT_EXPIRY=24h

# Bootstrap admin user (created on first startup if no users exist)
ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD is required in LOCAL mode for bootstrap
ADMIN_PASSWORD=change-me-strong-password

# ─── OAuth / OpenID Connect (only needed when AUTH_MODE=OAUTH) ─────────────────
# OIDC client credentials from your identity provider
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# Frontend callback URL where the OIDC provider redirects after login
# OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
# OIDC issuer URL (used to discover .well-known/openid-configuration)
# OAUTH_ISSUER_URL=https://your-idp.example.com

# ─── Keycloak Firewall (only when AUTH_MODE=KEYCLOAK_FIREWALL) ─────────────────
# Full URL to the Keycloak realm (used for JWKS and token validation)
# KEYCLOAK_REALM_URL=https://auth.rearch.engineer/realms/rearch
# Backend client ID in Keycloak (confidential client for service-to-service)
# KEYCLOAK_CLIENT_ID=rearch-backend
# Backend client secret (from Keycloak admin console)
# KEYCLOAK_CLIENT_SECRET=your-client-secret

# ─── Docker / Swarm Configuration ─────────────────────────────────────────────
# Overlay network name for container routing (used in KEYCLOAK_FIREWALL / Swarm mode)
# DOCKER_NETWORK=rearch-net
# Base domain for the application (used for dynamic subdomain routing of containers)
# APP_DOMAIN=rearch.engineer
# Frontend public URL (used for CORS and Keycloak redirects)
# FRONTEND_URL=https://app.rearch.engineer

# ─── Redis Configuration (for BullMQ job queue) ───────────────────────────────
# Option 1: Use Redis URL (simplest, works with cloud providers)
REDIS_URL=redis://localhost:6379
# Option 2: Use individual parameters (comment out REDIS_URL if using this approach)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
# REDIS_TLS=false

# Docker Container Configuration
CONVERSATION_CONTAINER_IMAGE=your-docker-image:latest

# ─── LLM Provider Encryption ──────────────────────────────────────────────────
# 64-character hex string (32 bytes) for AES-256-GCM encryption of API keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, falls back to deriving a key from JWT_SECRET.
# ENCRYPTION_KEY=

# Legacy: ANTHROPIC_API_KEY is no longer used directly. Configure LLM
# providers and their API keys via the Administration > LLM Providers panel.
# ANTHROPIC_API_KEY=

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# Applies to POST /api/auth/login and POST /api/auth/register.
# Limits are per client IP (uses X-Forwarded-For when behind a reverse proxy).
# Uses an in-memory store by default (suitable for single-instance deployments).
#
# Max requests per window (default: 10)
RATE_LIMIT_AUTH_MAX=10
# Window duration in milliseconds (default: 900000 = 15 minutes)
RATE_LIMIT_AUTH_WINDOW_MS=900000

# ─── MCP Proxy ─────────────────────────────────────────────────────────────
# URL of the MCP proxy service (used to forward status/reload requests)
MCP_PROXY_URL=http://localhost:3100
# For local dev: URL containers use to reach the proxy (host.docker.internal)
# Shared secret for container-to-proxy authentication (leave empty to disable)
MCP_PROXY_SECRET=
